rules_version = '2';

// NaukriMitra is a single-user app. All reads/writes happen SERVER-SIDE through
// the Firebase Admin SDK (service account), which bypasses these rules entirely.
// So we lock the client SDK completely — nothing can touch Firestore from a browser.
//
// Paste this in: Firebase console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
