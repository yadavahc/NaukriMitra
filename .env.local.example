# ─── Copy this file to .env.local and fill in your values ───

# Firebase Admin (create a project at https://console.firebase.google.com → enable Firestore)
# Project Settings → Service accounts → "Generate new private key" → copy from the JSON:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
# Paste the full private key on ONE line, keeping the literal \n sequences:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Single-user lock — only this email may sign in
ALLOWED_EMAIL=your-email@gmail.com

# Personal details kept out of the repo (used to auto-fill applications)
PROFILE_PHONE=+91 XXXXXXXXXX
PROFILE_ADDRESS=Your address, City PIN

# Password gate (this is how YOU log in) + a long random cookie secret
APP_PASSWORD=set-a-strong-password
AUTH_SECRET=paste-a-long-random-string-here

# AI providers (OpenAI is tried first, Gemini used as fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Fully-automated apply (Playwright). true = browser fills forms; AUTO_SUBMIT true = it also clicks Submit.
AUTO_APPLY_BROWSER=false
AUTO_SUBMIT=false

# Adzuna job API (free key: https://developer.adzuna.com/) — optional but recommended for India jobs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Comma-separated Greenhouse/Lever company slugs to auto-apply into (startups you like)
GREENHOUSE_BOARDS=
LEVER_BOARDS=
GREENHOUSE_API_KEY=
